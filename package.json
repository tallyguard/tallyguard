{
  "name": "tallyguard",
  "version": "0.6.0",
  "description": "Deterministic static analyzer that flags missing rate limits and unsafe money-handling in web app source code before it ships.",
  "keywords": [
    "static-analysis",
    "sast",
    "security",
    "rate-limiting",
    "denial-of-wallet",
    "nextjs",
    "express",
    "stripe",
    "idempotency",
    "sarif",
    "cli",
    "ai",
    "typescript"
  ],
  "type": "module",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tallyguard/tallyguard.git"
  },
  "homepage": "https://github.com/tallyguard/tallyguard#readme",
  "bugs": "https://github.com/tallyguard/tallyguard/issues",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "npm@10.9.4",
  "main": "dist/index.js",
  "bin": {
    "tallyguard": "dist/cli/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "npm run build",
    "benchmark": "npm run build && node tools/benchmark/score.mjs",
    "realworld": "npm run build && node tools/realworld/run.mjs",
    "app:dev": "probot run ./dist/app/probot-app.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test --pass-with-no-tests",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@types/node": "^26.0.0",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^10.5.0",
    "prettier": "^3.8.4",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "ajv": "^8.20.0",
    "probot": "^14.3.2",
    "tree-sitter-python": "^0.25.0",
    "ts-morph": "^28.0.0",
    "web-tree-sitter": "^0.26.9"
  },
  "overrides": {
    "esbuild": "^0.28.1"
  }
}
